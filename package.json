{
  "name": "compro-layangdigital",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:web": "pnpm --filter @compro-layangdigital/web dev",
    "dev:cms": "pnpm --filter @compro-layangdigital/cms develop",
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter @compro-layangdigital/web build"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}